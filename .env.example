# Copy this file to .env and fill in your values

# Firebase config (from Firebase Console > Project Settings > Your Apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Anthropic Claude API key (from console.anthropic.com)
# For the prototype this is set via the Profile screen in the app (stored in SecureStore)
# OR you can set it here for development:
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Google Sign-In (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
